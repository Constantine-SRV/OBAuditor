<?xml version="1.0" encoding="UTF-8"?>
<!--
    OceanBase Auditor — конфигурация
    ====================================

    CollectorId — уникальный идентификатор этого экземпляра сервиса.
                  Если не указан или пустой — берётся hostname машины.

    LogLevel     — уровень логирования: DEBUG | INFO | ERROR

    IgnoredUsers — служебные УЗ, исключаемые из аудита логинов.
                   Дефолт: ocp_monitor, proxy_ro, proxyro.

    DdlDclAuditMode — режим сбора DDL/DCL аудита из GV$OB_SQL_AUDIT:
                   0 — отключён
                   1 — основной коллектор (собирает всегда)
                   2 — резервный коллектор (собирает только если основной
                       не обновлял audit_collector_state более 2 минут)
                   Рекомендация: на одном узле ставить 1, на остальных 2.

    Cleanup      — управление размером таблиц:
        CleanupMinute      — минута часа (0–59) когда запускается удаление.
                             -1 = отключено.
                             Пример: узел 1 = 0, узел 2 = 20, узел 3 = 40
                             → гарантированное удаление раз в час.
        MaxDdlDclAuditRows — макс. строк в ddl_dcl_audit_log (0 = без лимита)
        MaxSessionsRows    — макс. строк в sessions (0 = без лимита)

    ObProxyLogPaths  — пути до директорий с логами OBProxy (obproxy.log*)
    ObServerLogPaths — пути до директорий с логами OBServer (observer.log*)

    SystemTenantConnection — подключение к системному тенанту
-->
<AppConfig>

    <!-- Идентификатор экземпляра сервиса (если пусто — берётся hostname) -->
    <CollectorId></CollectorId>

    <!-- Уровень логирования: DEBUG | INFO | ERROR -->
    <LogLevel>ERROR</LogLevel>

    <!-- Служебные УЗ, исключаемые из аудита логинов -->
    <IgnoredUsers>
        <User>ocp_monitor</User>
        <User>proxy_ro</User>
        <User>proxyro</User>
    </IgnoredUsers>

    <!--
        DDL/DCL аудит из GV$OB_SQL_AUDIT
        0 = отключён | 1 = основной коллектор | 2 = резервный
    -->
    <DdlDclAuditMode>1</DdlDclAuditMode>

    <!-- Управление размером таблиц -->
    <Cleanup>
        <!-- Минута часа для запуска очистки (-1 = отключено) -->
        <CleanupMinute>0</CleanupMinute>
        <!-- Максимум строк в ddl_dcl_audit_log -->
        <MaxDdlDclAuditRows>500000</MaxDdlDclAuditRows>
        <!-- Максимум строк в sessions -->
        <MaxSessionsRows>500000</MaxSessionsRows>
    </Cleanup>

    <!-- Пути до логов OBProxy -->
    <ObProxyLogPaths>
        <Path>\\192.168.55.200\obproxy_log</Path>
        <!-- <Path>\\192.168.55.201\obproxy_log</Path> -->
    </ObProxyLogPaths>

    <!-- Пути до логов OBServer -->
    <ObServerLogPaths>
        <Path>\\192.168.55.205\oceanbase_log</Path>
        <!-- <Path>\\192.168.55.206\oceanbase_log</Path> -->
        <!-- <Path>\\192.168.55.207\oceanbase_log</Path> -->
    </ObServerLogPaths>

    <!-- Подключение к системному тенанту -->
    <SystemTenantConnection>
        <Hosts>
            <Host>192.168.55.205:2881</Host>
            <!-- <Host>192.168.55.206:2881</Host> -->
        </Hosts>
        <User>ob_cluster_admin@sys</User>
        <Password>qaz123</Password>
        <Database>oceanbase</Database>
    </SystemTenantConnection>

</AppConfig>